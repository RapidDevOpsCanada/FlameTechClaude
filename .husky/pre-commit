#!/usr/bin/env sh
# Pre-commit: run the image optimization pipeline against any staged
# raster images under public/images/. Converted files + the refreshed
# featured-image-dimensions.ts get re-staged so the commit that lands
# already includes the optimized versions and updated references.

# Collect staged image paths (added or modified). xargs -0 keeps spaces
# in filenames safe.
staged=$(git diff --cached --name-only --diff-filter=AM -z \
  | tr '\0' '\n' \
  | grep -E '^public/images/.*\.(jpe?g|png)$' || true)

if [ -n "$staged" ]; then
  # shellcheck disable=SC2086
  echo "$staged" | xargs node scripts/optimize-images.mjs
else
  # Even if no images are staged, refresh the dimensions map in case
  # an image was removed in the same commit.
  node scripts/optimize-images.mjs
fi

# Re-stage anything the script touched (deleted JPGs, new WebPs,
# rewritten references, refreshed dimensions module).
git add public/images src/lib/featured-image-dimensions.ts
git add -u

# Guard against empty alt="" on rendered images. SEO crawlers count
# alt="" as missing alt regardless of WCAG decorative-image rules,
# which drops the site's alt-coverage score and pulls down image SEO.
# Every <img> and <Image> in this repo must have meaningful alt text —
# review avatars, author headshots, mega-menu promos, etc. all derive
# their alt from an adjacent label (author name, promo title) so this
# is enforceable. If a future image is truly decorative, change the
# tactic (e.g. wrap in a <span aria-hidden>) rather than alt="".
staged_tsx=$(git diff --cached --name-only --diff-filter=AM -z \
  | tr '\0' '\n' \
  | grep -E '\.(tsx?|jsx?)$' || true)

if [ -n "$staged_tsx" ]; then
  empty_alts=$(echo "$staged_tsx" | xargs grep -l 'alt=""' 2>/dev/null || true)
  if [ -n "$empty_alts" ]; then
    echo "Error: empty alt=\"\" found in:" >&2
    echo "$empty_alts" | sed 's/^/  /' >&2
    echo "" >&2
    echo "Empty alt is counted as 'missing alt' by SEO crawlers." >&2
    echo "Use meaningful alt text. For avatar/promo images, derive it" >&2
    echo "from the adjacent label (author name, promo title, etc)." >&2
    exit 1
  fi
fi
