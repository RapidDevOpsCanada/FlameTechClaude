# Database (required) — Neon / Postgres connection string.
# Used by /api/lead for lead form submissions and the reviews seed.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# or POSTGRES_URL / POSTGRES_URL_NON_POOLING (Vercel Neon integration)

# -----------------------------------------------------------------------
# Lead form submission endpoint (REQUIRED at launch).
#
# The contact / quote form POSTs directly to Formspree, which handles
# spam filtering and email delivery to the owner's inbox. Free tier
# (50 submissions/month) is sufficient for most small service
# businesses. Set this in Vercel project settings → Environment
# Variables. NEXT_PUBLIC_ prefix is intentional — Formspree endpoint
# URLs are opaque IDs meant to be embedded client-side.
# -----------------------------------------------------------------------
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx
