# Database (required) — Neon / Postgres connection string.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# or POSTGRES_URL / POSTGRES_URL_NON_POOLING (Vercel Neon integration)

# Lead form email notifications (optional but recommended).
# Set both to enable. Missing either disables the email channel.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFY_EMAIL=owner@flametechplumbing.ca
LEAD_NOTIFY_FROM=leads@flametechplumbing.ca

# Lead form SMS notifications (optional but recommended for
# emergency leads). All four required together; missing any disables
# the SMS channel. Numbers in E.164.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+15875551234
TWILIO_TO=+15878343668
