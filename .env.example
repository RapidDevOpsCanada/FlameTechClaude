# Database (required) — Neon / Postgres connection string.
# Used by /api/lead for lead form submissions and the reviews seed.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# or POSTGRES_URL / POSTGRES_URL_NON_POOLING (Vercel Neon integration)

# -----------------------------------------------------------------------
# Lead form submission endpoint (OPTIONAL override).
#
# The contact / quote form has the production Formspree URL hardcoded
# in src/components/QuoteForm.tsx — no env var is required to run.
# Set this only if you want to point a staging deploy at a different
# Formspree form (e.g. to test without sending real owner alerts).
# -----------------------------------------------------------------------
# NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/xxxxxxxx
