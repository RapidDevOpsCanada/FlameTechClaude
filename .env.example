# Database (required) — Neon / Postgres connection string.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# or POSTGRES_URL / POSTGRES_URL_NON_POOLING (Vercel Neon integration)

# -----------------------------------------------------------------------
# Lead form email notification (RECOMMENDED for launch).
# Without this, leads land silently in Postgres only — owners get no
# alert when the contact form is submitted. Free tier (Resend) covers
# 3000 emails/month, way more than needed for a small service business.
# -----------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
LEAD_NOTIFY_EMAIL=owner@flametechplumbing.ca
# Optional. Defaults to leads@flametechplumbing.ca. Must be a verified
# sender on whichever domain you set up in Resend.
LEAD_NOTIFY_FROM=leads@flametechplumbing.ca

# -----------------------------------------------------------------------
# Lead form SMS notification (OPTIONAL — add later if email proves
# insufficient).
#
# Email alerts are usually enough when the owners have push email on
# their phones. Add SMS only if you observe missed leads or callback
# times > 30 minutes after launch, OR if emergency-flagged leads
# (burst pipes, no-heat winter calls) make up a meaningful share of
# inbound. All four vars required together; missing any disables the
# SMS channel cleanly. Numbers in E.164. Cost ~CAD $0.01/SMS.
# -----------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+15875551234
# TWILIO_TO=+15878343668
